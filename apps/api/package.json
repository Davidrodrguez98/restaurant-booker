{
  "name": "api",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "build": "tsc",
    "clean": "rm -rf dist",
    "dev": "nodemon --exec \"node -r esbuild-register ./src/index.ts\" -e .ts",
    "lint": "tsc --noEmit && eslint \"src/**/*.ts*\" --max-warnings 0",
    "seed": "node -r esbuild-register ./src/db/seed.ts",
    "start": "node -r esbuild-register ./src/index.ts",
    "test": "jest --detectOpenHandles"
  },
  "jest": {
    "preset": "@repo/jest-presets/node",
    "moduleNameMapper": {
      "^@/(.*)$": "<rootDir>/src/$1"
    }
  },
  "dependencies": {
    "@better-auth/drizzle-adapter": "^1.6.23",
    "@neondatabase/serverless": "^1.1.0",
    "@repo/logger": "workspace:*",
    "better-auth": "^1.6.23",
    "body-parser": "^1.20.5",
    "cors": "^2.8.5",
    "dotenv": "^17.4.2",
    "drizzle-orm": "0.45.2",
    "drizzle-seed": "^0.3.1",
    "express": "^4.22.2",
    "morgan": "^1.10.0",
    "postgres": "^3.4.9",
    "swagger-jsdoc": "^6.3.0",
    "swagger-ui-express": "^5.0.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@jest/globals": "^30.2.0",
    "@repo/eslint-config": "workspace:*",
    "@repo/jest-presets": "workspace:*",
    "@repo/typescript-config": "workspace:*",
    "@types/body-parser": "^1.19.5",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/morgan": "^1.9.9",
    "@types/node": "^20.11.24",
    "@types/supertest": "^7.2.0",
    "drizzle-kit": "0.31.10",
    "esbuild": "^0.28.1",
    "esbuild-register": "^3.5.0",
    "eslint": "^10.6.0",
    "jest": "^30.2.0",
    "nodemon": "^3.1.0",
    "supertest": "^7.2.2",
    "tsx": "^4.23.0",
    "typescript": "6.0.3"
  }
}
