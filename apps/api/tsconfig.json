{
	"extends": "@repo/typescript-config/base.json",
	"compilerOptions": {
		"target": "es2022",
		"lib": ["ES2022"],
		"declaration": false,
		"declarationMap": false,
		"outDir": "./dist",
		"rootDir": "./src",
		"strictNullChecks": true,
		"ignoreDeprecations": "6.0",
		"types": ["node"],
		"baseUrl": ".",
		"paths": {
			"@/*": ["./src/*"]
		}
	},
	"exclude": ["node_modules"],
	"include": ["src"]
}
